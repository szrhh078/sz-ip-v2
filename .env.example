# Firebase configuration for Admin login (Settings > Admin Account, /admin)
# Copy this file to .env.local for local development and fill in your values
# from the Firebase Console > Project Settings > General > Your apps > Web app.
#
# On Vercel: add these as Environment Variables in Project Settings > Environment Variables
# (with the exact same VITE_ prefix), then redeploy.
#
# If these are left empty, the app falls back to the built-in local
# admin login (username/password stored in the browser).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
